ENVIRONMENT=local
LOG_LEVEL=DEBUG
HOST=0.0.0.0
PORT=3000
REDIS_URL=redis://redis:6379/0
OPT_RESULT_TTL_SECONDS=259200
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Pre-orders (mutable quote): seeds the "preorders" section of settings.
# At runtime the source of truth is the settings table (PATCH /settings/preorders).
PREORDER_VALIDITY_DAYS=15
MAX_OPEN_PREORDERS_PER_CLIENT=5

# Maderable frontend: base for the client review link.
# The dashboard uses HashRouter, so the base must end in "/#" for
# {FRONTEND_BASE_URL}/review/{token} to resolve to the SPA route.
FRONTEND_BASE_URL=http://localhost:3001/#

# Edge banding: waste applied over the net length before rounding to the billed meter
EDGE_BANDING_WASTE_FACTOR=0.10

# Order attachments (anexos): PDFs/screenshots stored on local disk. In Docker
# this points at a mounted volume (/src/uploads); locally it defaults to ./uploads.
ATTACHMENTS_DIR=/src/uploads
MAX_ATTACHMENT_MB=10

# Authentication (JWT). SECRET_KEY signs the tokens: MANDATORY in production;
# falls back to a development placeholder in local/staging. The access token is
# short-lived (ACCESS_TOKEN_EXPIRE_MINUTES) and renewed via the refresh token,
# whose validity is REFRESH_TOKEN_EXPIRE_DAYS. See docs/AUTH.md.
SECRET_KEY=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# First administrator: idempotent seed applied by scripts/seed_admin.py
# (run `make seed-admin`), NOT by a migration. If both are set and no user
# exists with that email, the script creates it with the "administrador" role.
# Empty = nothing is seeded.
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=cambia-esta-clave

# Database (PostgreSQL via Docker)
DATABASE_URL=postgresql://cutter:cutter@postgres:5432/cutter_db

# Company data (shown on the proforma PDF)
COMPANY_NAME=Mi Empresa
COMPANY_TAGLINE=eslogan de la empresa
COMPANY_EMAIL=correo@empresa.com
COMPANY_PHONE=0990000000 / 0990000001
# Branches as single-line JSON (commas in the address are fine)
COMPANY_BRANCHES=[{"name":"Sucursal 1","address":"Calle Principal y Secundaria"},{"name":"Sucursal 2","address":"Av. Central y Transversal"}]